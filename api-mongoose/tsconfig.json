{
   "compilerOptions": {
      "lib": [
         "es5",
         "es6"
      ],
      "target": "es5",
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./build",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "sourceMap": true,
      "typeRoots": ["./node_modules/@types"]
   },
   "files": ["src/types/custom.d.ts"],
   "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}