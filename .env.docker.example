# Copy to `.env` on the VPS and fill in production values.
# Used by: docker compose up

# --- Public URLs (cPanel / Apache terminates SSL) ---
WEB_URL=https://winkwebhealth.com
VITE_API_URL=https://api.winkwebhealth.com

# --- API ---
PORT=4545
DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/winkwebhealth
JWT_SECRET=change-me-to-a-long-random-string

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# --- Redis (Docker internal hostname) ---
REDIS_URL=redis://redis:6379

# --- Email alerts (cPanel SMTP) ---
# If SMTP_PASS contains $, wrap in single quotes: SMTP_PASS='p@ss$word'
SMTP_HOST=mail.winkwebhealth.com
SMTP_PORT=465
SMTP_USER=alerts@winkwebhealth.com
SMTP_PASS=
SMTP_FROM=alerts@winkwebhealth.com
